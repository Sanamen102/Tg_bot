# ===== Telegram =====
# Токен бота от @BotFather
BOT_TOKEN=123456789:AAAA-your-token-here

# Разрешённые Telegram user_id через запятую (узнать свой: @userinfobot)
ALLOWED_USER_IDS=123456789

# Куда слать плановые уведомления и алерты (по умолчанию — первый из ALLOWED_USER_IDS)
# ADMIN_CHAT_ID=123456789

# Прокси для Telegram API, если провайдер блокирует api.telegram.org.
# Поддерживаются socks5:// и http://.
# Если используете xray-контейнер из docker-compose.yml (Amnezia/VLESS+Reality):
#   TELEGRAM_PROXY=socks5://xray:1080
# Внешний прокси: TELEGRAM_PROXY=socks5://user:pass@1.2.3.4:1080
# TELEGRAM_PROXY=

# ===== Docker =====
# Контейнеры, которые бот имеет право перезапускать (через запятую)
DOCKER_RESTART_WHITELIST=jellyfin,immich_server

# ===== Диски =====
# Формат: "метка:/путь" через запятую. Корень хоста примонтирован в /host/root.
# Пример с отдельным диском под медиа: root:/host/root,media:/host/root/mnt/media
DISK_PATHS=root:/host/root
# Порог заполнения диска для предупреждений, в процентах
DISK_ALERT_THRESHOLD=90

# ===== Immich =====
# Адрес Immich, доступный из контейнера бота.
# Если Immich в Docker на той же машине — удобно использовать IP хоста или его имя.
IMMICH_URL=http://192.168.1.10:2283
# API-ключ: Immich -> Настройки аккаунта -> API Keys.
# Для статистики (/immich_status) нужен ключ администратора, для остального — любой.
IMMICH_API_KEY=

# ===== Jellyfin =====
JELLYFIN_URL=http://192.168.1.10:8096
# API-ключ: Jellyfin -> Панель управления -> API-ключи
JELLYFIN_API_KEY=
# Необязательно: id пользователя, от чьего имени смотреть медиатеку
# JELLYFIN_USER_ID=

# ===== Transmission =====
# Адрес веб-интерфейса Transmission. Пусто = функция отключена.
TRANSMISSION_URL=http://192.168.1.10:9091
# Логин/пароль, если в Transmission включена авторизация
TRANSMISSION_USER=
TRANSMISSION_PASSWORD=
# Кнопки выбора папки при добавлении magnet-ссылки.
# Формат: "Метка:/путь" через запятую. Путь — КАК ЕГО ВИДИТ КОНТЕЙНЕР Transmission
# (проверить маунт: sudo docker inspect transmission --format '{{json .Mounts}}').
# Пусто = всегда качать в папку Transmission по умолчанию.
TORRENT_DIRS=🎬 Фильм:/downloads/movie,📺 Сериал:/downloads/show,🎵 Музыка:/downloads/music,🏠 Домашнее:/downloads/home

# ===== Zapret (обход DPI на хосте) =====
# Бот управляет systemd-сервисом zapret по SSH с forced command.
# Оставьте ZAPRET_SSH_USER пустым, чтобы отключить функцию.
# Настройка ключа и forced command — см. README, раздел «Управление zapret».
ZAPRET_SSH_USER=
ZAPRET_SSH_HOST=host.docker.internal
ZAPRET_SSH_PORT=22
ZAPRET_SSH_KEY_PATH=/app/ssh/id_ed25519

# ===== Расписание =====
# Время ежедневного «воспоминания дня» (пустое значение отключает)
DAILY_MEMORY_TIME=09:00
# День и время еженедельного отчёта (пустое время отключает)
WEEKLY_REPORT_DAY=sun
WEEKLY_REPORT_TIME=18:00
# Интервал фонового мониторинга дисков и контейнеров, минуты (0 отключает)
MONITOR_INTERVAL_MINUTES=15
# Проверка питания ноутбука, секунды (0 отключает).
# Переход на аккумулятор = алерт «выключили свет», возврат сети = «свет дали».
POWER_CHECK_INTERVAL_SECONDS=60
# Порог заряда для критического алерта, %
BATTERY_LOW_THRESHOLD=25
# Проверка завершённых закачек Transmission, секунды (0 отключает)
TORRENT_CHECK_INTERVAL_SECONDS=120
# Порог температуры CPU для алерта о перегреве, °C
TEMP_ALERT_THRESHOLD=85
# Проверка интернета для отчёта «связь пропадала с X до Y», секунды (0 отключает)
INTERNET_CHECK_INTERVAL_SECONDS=60

# ===== Здоровье диска (SMART) =====
# Диски через запятую (узнать: lsblk -d -o NAME,TYPE,SIZE). Пусто = выкл.
# Требует раскомментировать devices/cap_add в docker-compose.yml!
# SMART_DEVICES=/dev/nvme0n1

# ===== Лимит заряда батареи =====
# Ноутбук 24/7 на зарядке убивает батарею; лимит 80% сильно продлевает ей жизнь.
# Требует поддержки ноутбуком (charge_control_end_threshold). 0 = не трогать.
BATTERY_CHARGE_LIMIT=80

# ===== Вотчер веб-сервисов =====
# "Метка:URL" через запятую — бот алертит при недоступности, статус в /today.
# WATCH_URLS=Navidrome:http://192.168.1.10:4533,AdGuard:http://192.168.1.10:3000

# ===== Мониторинг AWG-туннеля до VPS =====
# Адрес, доступный ТОЛЬКО через туннель — внутренний IP САМОГО VPS в VPN-сети.
# Важно: узнайте его точно (docker exec amnezia-awg2 ip -4 addr show awg0) —
# у Amnezia это обычно 10.8.1.0. Не перепутайте с адресом клиента (телефона!):
# иначе бот будет мониторить телефон, а не туннель.
# Проверяется ICMP-пингом; статус в /status и /today, алерт при падении.
# AWG_CHECK_HOST=10.8.1.0

# ===== История метрик и /graph =====
# Как часто записывать CPU/RAM/температуру, минуты (0 = выкл)
METRICS_INTERVAL_MINUTES=5
# Сколько дней хранить историю
METRICS_RETENTION_DAYS=14

# ===== Бэкап конфигов в Telegram (/backup) =====
# Каталоги ХОСТА через запятую — бот соберёт из них конфиг-файлы (yml/env/
# conf/json/sh/service и т.п., мелкие) и пришлёт tar.gz документом в чат.
# Архив содержит секреты — команда доступна только владельцу бота.
# BACKUP_PATHS=/home/san,/opt/zapret,/etc/amnezia,/etc/systemd/system
# Еженедельная отправка (пустое время = только вручную командой /backup)
BACKUP_DAY=sun
BACKUP_TIME=12:00

# Часовой пояс (влияет на расписание)
TZ=Europe/Moscow
