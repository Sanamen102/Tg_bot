# ===== Telegram =====
# Токен бота от @BotFather
BOT_TOKEN=123456789:AAAA-your-token-here

# Разрешённые Telegram user_id через запятую (узнать свой: @userinfobot)
ALLOWED_USER_IDS=123456789

# Куда слать плановые уведомления и алерты (по умолчанию — первый из ALLOWED_USER_IDS)
# ADMIN_CHAT_ID=123456789

# Прокси для Telegram API, если провайдер блокирует api.telegram.org.
# Поддерживаются socks5:// и http://.
# Если используете xray-контейнер из docker-compose.yml (Amnezia/VLESS+Reality):
#   TELEGRAM_PROXY=socks5://xray:1080
# Внешний прокси: TELEGRAM_PROXY=socks5://user:pass@1.2.3.4:1080
# TELEGRAM_PROXY=

# ===== Docker =====
# Контейнеры, которые бот имеет право перезапускать (через запятую)
DOCKER_RESTART_WHITELIST=jellyfin,immich_server

# ===== Диски =====
# Формат: "метка:/путь" через запятую. Корень хоста примонтирован в /host/root.
# Пример с отдельным диском под медиа: root:/host/root,media:/host/root/mnt/media
DISK_PATHS=root:/host/root
# Порог заполнения диска для предупреждений, в процентах
DISK_ALERT_THRESHOLD=90

# ===== Immich =====
# Адрес Immich, доступный из контейнера бота.
# Если Immich в Docker на той же машине — удобно использовать IP хоста или его имя.
IMMICH_URL=http://192.168.1.10:2283
# API-ключ: Immich -> Настройки аккаунта -> API Keys.
# Для статистики (/immich_status) нужен ключ администратора, для остального — любой.
IMMICH_API_KEY=

# ===== Jellyfin =====
JELLYFIN_URL=http://192.168.1.10:8096
# API-ключ: Jellyfin -> Панель управления -> API-ключи
JELLYFIN_API_KEY=
# Необязательно: id пользователя, от чьего имени смотреть медиатеку
# JELLYFIN_USER_ID=

# ===== Расписание =====
# Время ежедневного «воспоминания дня» (пустое значение отключает)
DAILY_MEMORY_TIME=09:00
# День и время еженедельного отчёта (пустое время отключает)
WEEKLY_REPORT_DAY=sun
WEEKLY_REPORT_TIME=18:00
# Интервал фонового мониторинга дисков и контейнеров, минуты (0 отключает)
MONITOR_INTERVAL_MINUTES=15
# Проверка питания ноутбука, секунды (0 отключает).
# Переход на аккумулятор = алерт «выключили свет», возврат сети = «свет дали».
POWER_CHECK_INTERVAL_SECONDS=60
# Порог заряда для критического алерта, %
BATTERY_LOW_THRESHOLD=25

# Часовой пояс (влияет на расписание)
TZ=Europe/Moscow
